static void LogThreadPool(string tag)
{
    ThreadPool.GetAvailableThreads(out var wAvail, out var ioAvail);
    ThreadPool.GetMaxThreads(out var wMax, out var ioMax);
    ThreadPool.GetMinThreads(out var wMin, out var ioMin);

    Console.WriteLine($"{DateTime.UtcNow:O} {tag} TP worker avail={wAvail}/{wMax} (min={wMin}) | IO avail={ioAvail}/{ioMax} (min={ioMin})");
}

LogThreadPool("BEFORE DB");
