using System;
using System.Collections.Generic;
using System.Data;
using System.IO;
using System.Reflection;
using System.Reflection.MetadataLoadContext;
using System.Runtime.InteropServices;

class Program
{
    static void Main()
    {
        // Your folder stays as-is. Do NOT change it.
        string folder = @"C:\dlls";  

        // Get path to .NET runtime assemblies (needed by MetadataLoadContext)
        string runtimeDir = RuntimeEnvironment.GetRuntimeDirectory();

        // Build list of assemblies for resolver:
        // 1. All DLLs in your folder (unchanged)
        // 2. All DLLs in the .NET runtime folder (required)
        var assemblyPaths = new List<string>();
        assemblyPaths.AddRange(Directory.GetFiles(folder, "*.dll"));
        assemblyPaths.AddRange(Directory.GetFiles(runtimeDir, "*.dll"));

        var resolver = new PathAssemblyResolver(assemblyPaths);

        using var mlc = new MetadataLoadContext(resolver);

        DataTable table = CreateDependencyTable();

        foreach (string dllPath in Directory.GetFiles(folder, "*.dll"))
        {
            Assembly asm = mlc.LoadFromAssemblyPath(dllPath);

            var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            WalkDependenciesToDataTable(
                rootDll: Path.GetFileName(dllPath),
                assembly: asm,
                mlc: mlc,
                visited: visited,
                nestingLevel: 1,
                table: table
            );
        }

        // Display results
        Console.WriteLine("\n=== DEPENDENCIES FOUND ===\n");

        foreach (DataRow row in table.Rows)
        {
            Console.WriteLine(
                $"{row["RootDll"],-32} → {row["DependencyDll"],-32}  v{row["DependencyDllVersion"],-12}  (Level {row["NestingLevel"]})"
            );
        }
    }

    static DataTable CreateDependencyTable()
    {
        var dt = new DataTable();
        dt.Columns.Add("RootDll", typeof(string));
        dt.Columns.Add("DependencyDll", typeof(string));
        dt.Columns.Add("DependencyDllVersion", typeof(string));
        dt.Columns.Add("NestingLevel", typeof(int));
        return dt;
    }

