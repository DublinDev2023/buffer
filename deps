using System;
using System.Collections.Generic;
using System.Data;
using System.IO;
using System.Reflection;
using System.Reflection.MetadataLoadContext;

class Program
{
    static void Main()
    {
        string folder = @"C:\dlls";

        var dllPaths = Directory.GetFiles(folder, "*.dll");

        // Resolver for all DLLs in the directory
        var resolver = new PathAssemblyResolver(dllPaths);
        using var mlc = new MetadataLoadContext(resolver);

        // Create the output table
        DataTable table = CreateDependencyTable();

        foreach (string dll in dllPaths)
        {
            var asm = mlc.LoadFromAssemblyPath(dll);
            var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            WalkDependenciesToDataTable(
                rootDll: Path.GetFileName(dll),
                assembly: asm,
                mlc: mlc,
                visited: visited,
                nestingLevel: 1,
                table: table
            );
        }

        // Output example (optional)
        foreach (DataRow row in table.Rows)
        {
            Console.WriteLine(
                $"{row["RootDll"]} -> {row["DependencyDll"]} v{row["DependencyDllVersion"]} (Level {row["NestingLevel"]})");
        }
    }

    static DataTable CreateDependencyTable()
    {
        var dt = new DataTable();
        dt.Columns.Add("RootDll", typeof(string));
        dt.Columns.Add("DependencyDll", typeof(string));
        dt.Columns.Add("DependencyDllVersion", typeof(string));
        dt.Columns.Add("NestingLevel", typeof(int));
        return dt;
    }

    static void WalkDependenciesToDataTable(
        string rootDll,
        Assembly assembly,
        MetadataLoadContext mlc,
        HashSet<string> visited,
        int nestingLevel,
        DataTable table)
    {
        foreach (var name in assembly.GetReferencedAssemblies())
        {
            // Skip framework-level assemblies
            if (name.Name.StartsWith("System") ||
                name.Name.StartsWith("Microsoft") ||
                name.Name.Equals("netstandard"))
                continue;

            if (visited.Contains(name.FullName))
                continue;

            visited.Add(name.FullName);

            // Add row to DataTable
            table.Rows.Add(
                rootDll,
                name.Name,
                name.Version?.ToString() ?? "",
                nestingLevel
            );

            try
            {
                var depAsm = mlc.LoadFromAssemblyName(name);

                // recurse
                WalkDependenciesToDataTable(
                    rootDll,
                    depAsm,
                    mlc,
                    visited,
                    nestingLevel + 1,
                    table
                );
            }
            catch
            {
                // Missing dependency -> still logged in table
            }
        }
    }
}
